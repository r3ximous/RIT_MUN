---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found | RIT MUN">
	<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
		<h1 class="text-6xl text-brand-orange font-extrabold mb-4">404</h1>
		<p class="text-2xl text-brand-dark mb-8">Oops! We couldn't find that page.</p>
		<p class="text-lg text-gray-600 mb-8 max-w-lg">If you are looking for an old conference page, it may have been moved or archived. Please use the navigation above to return to our new website.</p>
		<a href="/" class="bg-brand-orange text-white px-8 py-3 rounded-full font-bold hover:bg-orange-600 transition-colors shadow-md">Go to Homepage</a>
	</div>
</Layout>