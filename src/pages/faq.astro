---
import { getCollection } from "astro:content";
import { HelpCircle } from "lucide-react";
import Layout from "../layouts/Layout.astro";

const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="RIT MUN | Frequently Asked Questions">
  <div class="max-w-3xl mx-auto px-6 py-20 animate-in fade-in">
    <div class="text-center mb-16">
      <div
        class="inline-flex justify-center items-center bg-orange-100 p-4 rounded-full text-brand-orange mb-6"
      >
        <HelpCircle className="w-10 h-10" client:load />
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-brand-dark mb-6">
        Frequently Asked Questions
      </h1>
      <p class="text-xl text-gray-600">
        Got questions? We've got answers. If you can't find what you're looking
        for, feel free to contact us.
      </p>
    </div>

    <div class="space-y-6">
      {
        sortedFaqs.map((faq) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold bg-gray-100 text-gray-500 px-3 py-1 rounded-full uppercase tracking-wider">
                {faq.data.category}
              </span>
            </div>
            <h2 class="text-xl font-bold text-brand-dark mb-3">
              {faq.data.question}
            </h2>
            <p class="text-gray-600 leading-relaxed">{faq.data.answer}</p>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
