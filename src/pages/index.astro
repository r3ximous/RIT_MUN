---
import Layout from '../layouts/Layout.astro';
import CountdownTimer from '../components/react/CountdownTimer';
import { Globe, Users, Award, MapPin, ArrowRight } from 'lucide-react';
---
<Layout title="RIT MUN | Homepage">
	{/* Hero Section */}
	<section class="hero-section"
		style="background-image: radial-gradient(circle at center, #2a2a2a 0%, #1E1E1E 100%)">
		<div class="hero-bg-pattern">
			<svg class="hero-bg-svg" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
						<path d="M 40 0 L 0 0 0 40" fill="none" stroke="#F76902" stroke-width="1"/>
					</pattern>
				</defs>
				<rect width="100%" height="100%" fill="url(#grid)" />
			</svg>
		</div>
		
		<div class="hero-content">
			<div class="hero-badge">
				<Globe className="icon-sm" client:load />
				<span>RIT Model United Nations Conference</span>
			</div>
			<h1 class="hero-title">
				Diplomacy in <span class="text-brand-highlight">Action</span>
			</h1>
			<p class="hero-subtitle">
				Join hundreds of delegates at Rochester Institute of Technology for a weekend of rigorous debate, negotiation, and global problem-solving.
			</p>
			<div class="hero-actions">
				<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/registration`} class="hero-btn-primary">
					Register Now <ArrowRight className="icon-arrow-left" client:load />
				</a>
				<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/committees`} class="hero-btn-secondary">
					View Committees
				</a>
			</div>
		</div>
	</section>

	{/* Island Architecture: Countdown */}
	<CountdownTimer client:load />

	{/* About Section */}
	<section class="features-section">
		<div class="features-grid">
			<div class="feature-card">
				<div class="feature-icon-box">
					<Users className="icon-md" client:load />
				</div>
				<h3 class="feature-title">Diverse Committees</h3>
				<p class="feature-desc">
					From the fast-paced Crisis committees to the expansive General Assembly, we offer a dynamic range of topics suitable for all experience levels.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon-box">
					<Award className="icon-md" client:load />
				</div>
				<h3 class="feature-title">Skill Building</h3>
				<p class="feature-desc">
					Enhance your public speaking, negotiation, and policy-writing skills. RIT MUN is designed to challenge and grow tomorrow's leaders.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon-box">
					<MapPin className="icon-md" client:load />
				</div>
				<h3 class="feature-title">RIT Campus</h3>
				<p class="feature-desc">
					Experience the cutting-edge facilities of the Rochester Institute of Technology, blending technology with traditional diplomacy.
				</p>
			</div>
		</div>
	</section>
</Layout>
