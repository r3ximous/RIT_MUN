---
import { Image } from 'astro:assets';
import bannerImg from '../Images/banner_plain_2.png';
import Layout from '../layouts/Layout.astro';
import CountdownTimer from '../components/react/CountdownTimer';
import { Globe, Users, Award, MapPin, ArrowRight } from 'lucide-react';
---
<Layout title="RIT MUN | Homepage">
  {/* Hero Section */}
  <section class="relative text-white pt-24 pb-32 px-6 overflow-hidden min-h-[70vh] flex items-center">
    
    {/* Optimized Absolute Background Image */}
    <div class="absolute inset-0 w-full h-full z-0">
      <Image 
        src={bannerImg} 
        alt="RIT MUN Conference" 
        class="w-full h-full object-cover object-center"
        loading="eager"
      />
      {/* Dark overlay to guarantee text readability */}
      <div class="absolute inset-0 bg-brand-dark/20 bg-gradient-to-r from-brand-dark/95 to-brand-dark/40"></div>
    </div>
    
    {/* Content Area */}
    <div class="max-w-7xl mx-auto flex flex-col z-10 w-full relative">
      <div class="hero-content max-w-3xl text-center md:text-left space-y-6 mx-auto md:mx-0">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-brand-orange text-sm font-semibold mb-2 border border-brand-orange/30 backdrop-blur-sm">
          
          <span>RIT Model United Nations Conference</span>
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight">
          Diplomacy in <span class="text-brand-highlight">Action</span>
        </h1>
        
        <p class="text-lg md:text-xl lg:text-2xl text-gray-200 max-w-2xl mx-auto md:mx-0">
          Join hundreds of delegates at Rochester Institute of Technology for a weekend of rigorous debate, negotiation, and global problem-solving.
        </p>
        
        <div class="pt-6 flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href="/registration" class="hero-btn-primary">
            Register Now <ArrowRight/>
          </a>
          <a href="/committees" class="hero-btn-secondary backdrop-blur-md">
            View Committees
          </a>
        </div>
      </div>
    </div>
  </section>
  
	{/* Island Architecture: Countdown */}
	<CountdownTimer client:load />

	{/* About Section */}
	<section class="features-section">
		<div class="features-grid">
			<div class="feature-card">
				<div class="feature-icon-box">
					<Users className="icon-md" client:load />
				</div>
				<h3 class="feature-title">Diverse Committees</h3>
				<p class="feature-desc">
					From the fast-paced Crisis committees to the expansive General Assembly, we offer a dynamic range of topics suitable for all experience levels.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon-box">
					<Award className="icon-md" client:load />
				</div>
				<h3 class="feature-title">Skill Building</h3>
				<p class="feature-desc">
					Enhance your public speaking, negotiation, and policy-writing skills. RIT MUN is designed to challenge and grow tomorrow's leaders.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon-box">
					<MapPin className="icon-md" client:load />
				</div>
				<h3 class="feature-title">RIT Campus</h3>
				<p class="feature-desc">
					Experience the cutting-edge facilities of the Rochester Institute of Technology, blending technology with traditional diplomacy.
				</p>
			</div>
		</div>
	</section>
</Layout>
