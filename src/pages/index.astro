---
import Layout from '../layouts/Layout.astro';
---
<Layout title="RIT MUN | Homepage">
	<section class="py-24 space-y-8 flex flex-col items-center justify-center text-center bg-gradient-to-br from-brand-dark to-brand-orange text-white rounded-lg shadow-xl">
		<h1 class="text-6xl font-extrabold tracking-tight">RIT Model United Nations</h1>
		<p class="text-xl max-w-2xl">Join the definitive diplomatic simulation experience at Rochester Institute of Technology. Solve global crises. Build leadership. Change the world.</p>
		<p class="text-2xl font-semibold border-b-2 border-white pb-2 mb-4">Conference Dates: November 15-17, 2026</p>
		<div class="flex gap-4">
			<a href="/registration" class="bg-white text-brand-orange px-8 py-3 rounded-full font-bold hover:bg-gray-100 transition-colors shadow-md">Register Now</a>
			<a href="/committees" class="border-2 border-white px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-colors">View Committees</a>
		</div>
	</section>

	<section class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
		<div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">Diplomacy</h2>
			<p class="text-gray-600 mt-2">Engage in rigorous debate and negotiation on the world's most pressing issues.</p>
		</div>
		<div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">Leadership</h2>
			<p class="text-gray-600 mt-2">Develop critical thinking, public speaking, and conflict resolution skills.</p>
		</div>
		<div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">Community</h2>
			<p class="text-gray-600 mt-2">Build lasting connections with students from across the globe in a dynamic environment.</p>
		</div>
	</section>
</Layout>
