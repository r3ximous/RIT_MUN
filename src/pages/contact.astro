---
import Layout from '../layouts/Layout.astro';
---
<Layout title="RIT MUN | Contact">
	<h1 class="text-4xl font-extrabold text-brand-dark mb-8">Contact Us</h1>
	<p class="text-lg mb-8">Have a question? We're here to help.</p>

	<form class="max-w-lg bg-white p-8 rounded-lg shadow-md border-t-4 border-brand-orange space-y-6" action="mailto:mun@rit.edu" method="POST" enctype="text/plain">
		<div>
			<label class="block text-sm font-bold text-brand-dark mb-2" for="name">Name</label>
			<input type="text" id="name" name="name" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-brand-orange focus:border-brand-orange p-2 border" required />
		</div>
		<div>
			<label class="block text-sm font-bold text-brand-dark mb-2" for="email">Email</label>
			<input type="email" id="email" name="email" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-brand-orange focus:border-brand-orange p-2 border" required />
		</div>
		<div>
			<label class="block text-sm font-bold text-brand-dark mb-2" for="message">Message</label>
			<textarea id="message" name="message" rows="4" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-brand-orange focus:border-brand-orange p-2 border" required></textarea>
		</div>
		<button type="submit" class="w-full bg-brand-orange text-white py-3 rounded-md font-bold hover:bg-orange-600 transition-colors shadow-md">Send Message</button>
	</form>
</Layout>