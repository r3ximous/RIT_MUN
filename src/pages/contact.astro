---
import Layout from '../layouts/Layout.astro';
import { Mail, Phone, MapPin } from 'lucide-react';
---
<Layout title="RIT MUN | Contact Us">
  <div class="mun-89 animate-in fade-in slide-in-from-bottom-8">
    <div class="mun-90">
      <h1 class="mun-91">Get in Touch</h1>
      <p class="mun-92">
        Need assistance with registration, have questions about a committee, or want to sponsor our conference? Our Secretariat is here to help and we typically respond within 24 hours.
      </p>

      <div class="mun-93">
        <div class="mun-94">
          <div class="mun-95">
            <Mail className="mun-108" client:load/>
          </div>
          <div>
             <h3 class="mun-96">Email</h3>
             <a href="mailto:secgen@ritmun.org" class="mun-97">secgen@ritmun.org</a>
          </div>
        </div>
        
        <div class="mun-94">
          <div class="mun-95">
             <Phone className="mun-108" client:load/>
          </div>
          <div>
            <h3 class="mun-96">Phone</h3>
            <a href="tel:+15854752411" class="mun-98">(585) 475-2411</a>
          </div>
        </div>
        
        <div class="mun-94">
          <div class="mun-95">
            <MapPin className="mun-108" client:load/>
          </div>
          <div>
             <h3 class="mun-96">Office</h3>
             <address class="mun-99">
               Campus Center Room 1000<br/>
               Rochester Institute of Technology<br/>
               1 Lomb Memorial Dr<br/>
               Rochester, NY 14623
             </address>
          </div>
        </div>
      </div>
    </div>

    <div class="mun-100">
       <h2 class="mun-101">Send a Message</h2>
       <form class="mun-102" action="/success">
        <div class="mun-55">
          <label for="name" class="mun-103">Name</label>
          <input type="text" id="name" name="name" 
            class="mun-104" 
            placeholder="Jane Doe" required />
        </div>
        <div class="mun-55">
          <label for="email" class="mun-103">Email</label>
          <input type="email" id="email" name="email" 
            class="mun-104" 
            placeholder="jane@example.com" required />
        </div>
        <div class="mun-105">
          <label for="message" class="mun-103">Message</label>
          <textarea id="message" name="message" rows="5" 
            class="mun-106" 
            placeholder="How can we help you?" required></textarea>
        </div>
        <button type="submit" 
          class="mun-107">
          Send Message
        </button>
      </form>
    </div>
  </div>
</Layout>