---
import Layout from '../layouts/Layout.astro';
import { FileText } from 'lucide-react';
---
<Layout title="RIT MUN | Registration">
  <div class="mun-126 animate-in fade-in">
    <div class="mun-127">
      <div class="mun-128">
        <div>
          <h1 class="mun-129">Join the Debate</h1>
          <p class="mun-130">
            Secure your spot at the next RIT MUN conference. Registration includes access to all committee sessions, the delegate social, and conference materials.
          </p>
          <ul class="mun-131">
            <li class="mun-78">
              <div class="mun-132">1</div>
              <span>Early Bird Registration: $45</span>
            </li>
            <li class="mun-78">
              <div class="mun-132">2</div>
              <span>Regular Registration: $60</span>
            </li>
            <li class="mun-78">
              <div class="mun-132">3</div>
              <span>Delegation Fee: $30</span>
            </li>
          </ul>
        </div>
      </div>
      
      <div class="mun-133">
        <div class="mun-134">
          <FileText className="mun-145" client:load/>
        </div>
        <h2 class="mun-135">Registration Portal</h2>
        <p class="mun-136">
          We utilize MyMUN for all conference registrations, allocations, and payments to ensure a seamless experience. 
        </p>
        
        <div class="mun-137">
          <h3 class="mun-138">Key Deadlines:</h3>
          <ul class="mun-139">
            <li class="mun-140">
              <span>Early Bird Ends:</span>
              <span class="mun-141">September 15, 2026</span>
            </li>
            <li class="mun-142">
              <span>Regular Ends:</span>
              <span class="mun-141">October 20, 2026</span>
            </li>
            <li class="mun-143">
              <span>Position Papers Due:</span>
              <span class="mun-141">November 1, 2026</span>
            </li>
          </ul>
        </div>

        <a 
          href="https://example.com/register" 
          class="mun-144"
        >
          Apply on MyMUN
        </a>
      </div>
    </div>
  </div>
</Layout>