---
import Layout from '../layouts/Layout.astro';
import { FileText } from 'lucide-react';
---
<Layout title="RIT MUN | Registration">
  <div class="registration-page-wrapper animate-in fade-in">
    <div class="registration-card">
      <div class="registration-info-col">
        <div>
          <h1 class="registration-title">Join the Debate</h1>
          <p class="registration-desc">
            Secure your spot at the next RIT MUN conference. Registration includes access to all committee sessions, the delegate social, and conference materials.
          </p>
          <ul class="registration-steps">
            <li class="committee-meta-item">
              <div class="step-number">1</div>
              <span>Early Bird Registration: $45</span>
            </li>
            <li class="committee-meta-item">
              <div class="step-number">2</div>
              <span>Regular Registration: $60</span>
            </li>
            <li class="committee-meta-item">
              <div class="step-number">3</div>
              <span>Delegation Fee: $30</span>
            </li>
          </ul>
        </div>
      </div>
      
      <div class="registration-portal-col">
        <div class="portal-icon-box">
          <FileText className="icon-lg" client:load/>
        </div>
        <h2 class="portal-title">Registration Portal</h2>
        <p class="portal-desc">
          We utilize MyMUN for all conference registrations, allocations, and payments to ensure a seamless experience. 
        </p>
        
        <div class="deadlines-box">
          <h3 class="deadlines-title">Key Deadlines:</h3>
          <ul class="deadlines-list">
            <li class="deadline-item">
              <span>Early Bird Ends:</span>
              <span class="deadline-date">September 15, 2026</span>
            </li>
            <li class="deadline-item-mid">
              <span>Regular Ends:</span>
              <span class="deadline-date">October 20, 2026</span>
            </li>
            <li class="deadline-item-last">
              <span>Position Papers Due:</span>
              <span class="deadline-date">November 1, 2026</span>
            </li>
          </ul>
        </div>

        <a 
          href="https://example.com/register" 
          class="portal-action-btn"
        >
          Apply on MyMUN
        </a>
      </div>
    </div>
  </div>
</Layout>