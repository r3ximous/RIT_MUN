---
import Layout from '../layouts/Layout.astro';
---
<Layout title="RIT MUN | Schedule">
	<h1 class="text-4xl font-extrabold text-brand-dark mb-8">Conference Schedule</h1>
	<p class="text-gray-600">The schedule will be automatically generated from content collections.</p>
	<div class="mt-8 space-y-6">
		<div class="p-6 bg-white rounded-lg shadow-sm border-l-4 border-brand-orange">
			<h3 class="text-xl font-bold text-brand-dark">Friday, November 15</h3>
			<ul class="mt-4 space-y-2 border-l-2 border-gray-200 pl-4 ml-2">
				<li class="relative before:absolute before:-left-5 before:top-2 before:h-2 before:w-2 before:rounded-full before:bg-brand-orange">
					<span class="font-bold">4:00 PM</span> - Opening Ceremonies
				</li>
				<li class="relative before:absolute before:-left-5 before:top-2 before:h-2 before:w-2 before:rounded-full before:bg-brand-orange">
					<span class="font-bold">6:00 PM</span> - Committee Session 1
				</li>
			</ul>
		</div>
	</div>
</Layout>