---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { MapPin, Clock } from 'lucide-react';

const scheduleCollection = await getCollection('schedule');
const sortedDays = scheduleCollection.sort((a, b) => a.data.order - b.data.order);
---
<Layout title="RIT MUN | Schedule">
  <div class="mun-146 animate-in fade-in">
    <div class="mun-147">
      <h1 class="mun-148">Conference Schedule</h1>
      <p class="mun-149">
        Plan your weekend. All times are local (EST).
      </p>
    </div>

    <div class="mun-150">
      {sortedDays.map((dayPlan) => (
        <section class="mun-151 group">
          <div class="mun-152 group-hover:bg-black">
            <h2 class="mun-153">{dayPlan.data.day}</h2>
            <span class="mun-154">{dayPlan.data.date}</span>
          </div>
          
          <div class="mun-155">
            {dayPlan.data.events.map((event) => (
              <div class="mun-156">
                <div class="mun-157">
                  <Clock className="mun-163" client:load/>
                  <span class="mun-158">{event.time}</span>
                </div>
                
                <div class="mun-159">
                  <h3 class="mun-160">{event.title}</h3>
                  <div class="mun-161">
                    <MapPin className="mun-164" client:load/>
                    {event.location}
                    <span class="mun-162">•</span>
                    <span class={`px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold ${
                      event.type === 'Session' ? 'bg-blue-100 text-blue-800' :
                      event.type === 'Ceremony' ? 'bg-brand-orange text-white' :
                      event.type === 'Admin' ? 'bg-gray-200 text-gray-800' :
                      'bg-purple-100 text-purple-800'
                    }`}>
                      {event.type}
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>