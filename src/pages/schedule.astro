---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { MapPin, Clock } from 'lucide-react';

const scheduleCollection = await getCollection('schedule');
const sortedDays = scheduleCollection.sort((a, b) => a.data.order - b.data.order);
---
<Layout title="RIT MUN | Schedule">
  <div class="schedule-page-wrapper animate-in fade-in">
    <div class="schedule-header">
      <h1 class="schedule-title">Conference Schedule</h1>
      <p class="schedule-subtitle">
        Plan your weekend. All times are local (EST).
      </p>
    </div>

    <div class="schedule-days-list">
      {sortedDays.map((dayPlan) => (
        <section class="schedule-day-card group">
          <div class="schedule-day-header group-hover:bg-black">
            <h2 class="schedule-day-title">{dayPlan.data.day}</h2>
            <span class="schedule-day-date">{dayPlan.data.date}</span>
          </div>
          
          <div class="schedule-events">
            {dayPlan.data.events.map((event) => (
              <div class="schedule-event-item">
                <div class="event-time-col">
                  <Clock className="icon-clock" client:load/>
                  <span class="event-time">{event.time}</span>
                </div>
                
                <div class="event-details-col">
                  <h3 class="event-title">{event.title}</h3>
                  <div class="event-location-row">
                    <MapPin className="icon-map-pin" client:load/>
                    {event.location}
                    <span class="event-separator">•</span>
                    <span class={`px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold ${
                      event.type === 'Session' ? 'bg-blue-100 text-blue-800' :
                      event.type === 'Ceremony' ? 'bg-brand-orange text-white' :
                      event.type === 'Admin' ? 'bg-gray-200 text-gray-800' :
                      'bg-purple-100 text-purple-800'
                    }`}>
                      {event.type}
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>