---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { MapPin, Clock } from 'lucide-react';

const scheduleCollection = await getCollection('schedule');
const sortedDays = scheduleCollection.sort((a, b) => a.data.order - b.data.order);
---
<Layout title="RIT MUN | Schedule">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 animate-in fade-in duration-500">
    <div class="mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-brand-dark mb-6">Conference Schedule</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Plan your weekend. All times are local (EST).
      </p>
    </div>

    <div class="space-y-12 relative">
      {sortedDays.map((dayPlan) => (
        <section class="relative bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-lg transition-transform hover:-translate-y-1 group">
          <div class="bg-brand-dark px-8 py-6 flex justify-between items-center group-hover:bg-black transition-colors">
            <h2 class="text-3xl font-extrabold text-white">{dayPlan.data.day}</h2>
            <span class="text-brand-orange text-lg font-semibold bg-white/10 px-4 py-1 rounded-full">{dayPlan.data.date}</span>
          </div>
          
          <div class="divide-y divide-gray-100">
            {dayPlan.data.events.map((event) => (
              <div class="flex flex-col sm:flex-row px-8 py-6 hover:bg-orange-50/50 transition-colors relative">
                <div class="sm:w-1/3 mb-3 sm:mb-0 pt-1 flex items-start text-brand-orange">
                  <Clock className="w-5 h-5 mr-3 flex-shrink-0" client:load/>
                  <span class="font-bold text-lg leading-none">{event.time}</span>
                </div>
                
                <div class="sm:w-2/3">
                  <h3 class="text-xl font-bold text-brand-dark mb-2">{event.title}</h3>
                  <div class="flex items-center text-sm font-medium text-gray-500">
                    <MapPin className="h-4 w-4 mr-2 text-gray-400" client:load/>
                    {event.location}
                    <span class="mx-3 text-gray-300">•</span>
                    <span class={`px-3 py-1 rounded-full text-xs uppercase tracking-wider font-bold ${
                      event.type === 'Session' ? 'bg-blue-100 text-blue-800' :
                      event.type === 'Ceremony' ? 'bg-brand-orange text-white' :
                      event.type === 'Admin' ? 'bg-gray-200 text-gray-800' :
                      'bg-purple-100 text-purple-800'
                    }`}>
                      {event.type}
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>