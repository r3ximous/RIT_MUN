---
import { getCollection } from 'astro:content';
import { ChevronRight, Users, FileText } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';

const allCommittees = await getCollection('committees');
const sortedCommittees = allCommittees.sort((a, b) => a.data.order - b.data.order);
---
<Layout title="RIT MUN | Committees">
  <div class="mun-43 animate-in fade-in">
    <div class="mun-44">
      <h1 class="mun-45">Committees</h1>
      <p class="mun-46">
        Explore the councils for this year's conference. Each committee is designed to challenge delegates on pressing global issues.
      </p>
    </div>

    <div class="mun-47">
      {sortedCommittees.map((com) => (
        <a href={`/committees/${com.id}`} class="mun-48 group">
          <div class="mun-49">
            <div>
              <div class="mun-50">{com.data.type}</div>
              <h2 class="mun-51 group-hover:text-brand-orange">{com.data.name}</h2>
            </div>
            <span class={`px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap ${
              com.data.difficulty === 'Beginner' ? 'bg-green-100 text-green-800' :
              com.data.difficulty === 'Intermediate' ? 'bg-blue-100 text-blue-800' :
              'bg-purple-100 text-purple-800'
            }`}>
              {com.data.difficulty}
            </span>
          </div>
          
          <p class="mun-52">{com.data.description}</p>
          
          <div class="mun-53">
            <h3 class="mun-54">Agenda Topics</h3>
            <ul class="mun-55">
              {com.data.topics.map((topic) => (
                <li class="mun-56">
                  <ChevronRight className="mun-61" client:load />
                  <span class="mun-57">{topic}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="mun-58">
            <span class="mun-59">
              <Users className="mun-62" client:load /> Size: {com.data.size}
            </span>
            <span class="mun-60">
              View Guide <FileText className="mun-63" client:load />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>