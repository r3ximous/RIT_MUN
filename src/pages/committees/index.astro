---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="RIT MUN | Committees">
	<h1 class="text-4xl font-extrabold text-brand-dark mb-8">Committees</h1>
	<p class="text-lg mb-8">Browse the list of available committees below.</p>
	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		<a href="/committees/unsc" class="block p-6 bg-white shadow-md rounded-lg hover:shadow-lg transition-shadow border-l-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">United Nations Security Council</h2>
			<p class="text-gray-600 mt-2">Advanced • Crisis Simulation</p>
		</a>
		<a href="/committees/ecosoc" class="block p-6 bg-white shadow-md rounded-lg hover:shadow-lg transition-shadow border-l-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">Economic and Social Council</h2>
			<p class="text-gray-600 mt-2">Intermediate • Specialized</p>
		</a>
		<a href="/committees/disec" class="block p-6 bg-white shadow-md rounded-lg hover:shadow-lg transition-shadow border-l-4 border-brand-orange">
			<h2 class="text-2xl font-bold text-brand-dark">DISEC (General Assembly 1)</h2>
			<p class="text-gray-600 mt-2">Beginner • General Assembly</p>
		</a>
	</div>
</Layout>