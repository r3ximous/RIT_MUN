---
import { getCollection } from 'astro:content';
import { ChevronRight, Users, FileText } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';

const allCommittees = await getCollection('committees');
const sortedCommittees = allCommittees.sort((a, b) => a.data.order - b.data.order);
---
<Layout title="RIT MUN | Committees">
  <div class="committees-page-wrapper animate-in fade-in">
    <div class="committees-header">
      <h1 class="committees-title">Committees</h1>
      <p class="committees-subtitle">
        Explore the councils for this year's conference. Each committee is designed to challenge delegates on pressing global issues.
      </p>
    </div>

    <div class="committees-grid">
      {sortedCommittees.map((com) => (
        <a href={`/committees/${com.id}`} class="committee-card group">
          <div class="committee-card-header">
            <div>
              <div class="committee-type-badge">{com.data.type}</div>
              <h2 class="committee-card-title group-hover:text-brand-orange">{com.data.name}</h2>
            </div>
            <span class={`px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap ${
              com.data.difficulty === 'Beginner' ? 'bg-green-100 text-green-800' :
              com.data.difficulty === 'Intermediate' ? 'bg-blue-100 text-blue-800' :
              'bg-purple-100 text-purple-800'
            }`}>
              {com.data.difficulty}
            </span>
          </div>
          
          <p class="committee-card-desc">{com.data.description}</p>
          
          <div class="committee-card-agenda">
            <h3 class="agenda-title">Agenda Topics</h3>
            <ul class="agenda-list">
              {com.data.topics.map((topic) => (
                <li class="agenda-item">
                  <ChevronRight className="agenda-icon" client:load />
                  <span class="agenda-item-text">{topic}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="committee-card-footer">
            <span class="committee-size-info">
              <Users className="size-icon" client:load /> Size: {com.data.size}
            </span>
            <span class="committee-view-guide">
              View Guide <FileText className="view-guide-icon" client:load />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>