---
import { getCollection, render } from 'astro:content';
import { ChevronRight, Users, ArrowLeft, FileText } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allCommittees = await getCollection('committees');
  return allCommittees.map(com => ({
    params: { id: com.id },
    props: { committee: com },
  }));
}

const { committee } = Astro.props;
const { Content } = await render(committee);
---

<Layout title={`RIT MUN | ${committee.data.name}`}>
  <div class="mun-64 animate-in fade-in">
    <a href="/committees" class="mun-65">
      <ArrowLeft className="mun-85" client:load /> Back to Committees
    </a>

    <div class="mun-66">
      <div class="mun-67">
        <div class="mun-68">
          <div>
            <div class="mun-69">{committee.data.type}</div>
            <h1 class="mun-70">{committee.data.name}</h1>
          </div>
          <span class={`px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap self-start ${
            committee.data.difficulty === 'Beginner' ? 'bg-green-100 text-green-800' :
            committee.data.difficulty === 'Intermediate' ? 'bg-blue-100 text-blue-800' :
            'bg-purple-100 text-purple-800'
          }`}>
            {committee.data.difficulty}
          </span>
        </div>

        <p class="mun-71">
          {committee.data.description}
        </p>

        <div class="mun-72">
          <div class="mun-73">
            <h3 class="mun-74">
              <FileText className="mun-86" client:load/>
              Agenda Topics
            </h3>
            <ul class="mun-75">
              {committee.data.topics.map((topic) => (
                <li class="mun-56">
                  <ChevronRight className="mun-87" client:load />
                  <span class="mun-76">{topic}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="mun-77">
            <div class="mun-78">
              <div class="mun-79">
                <Users className="mun-88" client:load />
              </div>
              <div>
                <div class="mun-80">Committee Size</div>
                <div class="mun-81">{committee.data.size}</div>
              </div>
            </div>
            <a href="#" class="mun-82">
              Download Background Guide
            </a>
          </div>
        </div>
      </div>

      <div class="mun-83 prose prose-lg prose-headings:text-brand-dark prose-a:text-brand-orange">
        <h2 class="mun-84">Welcome Letter</h2>
        <Content />
      </div>
    </div>
  </div>
</Layout>