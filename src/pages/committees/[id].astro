---
import { getCollection, render } from 'astro:content';
import { ChevronRight, Users, ArrowLeft, FileText } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allCommittees = await getCollection('committees');
  return allCommittees.map(com => ({
    params: { id: com.id },
    props: { committee: com },
  }));
}

const { committee } = Astro.props;
const { Content } = await render(committee);
---

<Layout title={`RIT MUN | ${committee.data.name}`}>
  <div class="committee-detail-wrapper animate-in fade-in">
    <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/committees`} class="back-to-committees">
      <ArrowLeft className="icon-arrow-left" client:load /> Back to Committees
    </a>

    <div class="committee-detail-card">
      <div class="committee-detail-header">
        <div class="committee-detail-title-row">
          <div>
            <div class="committee-detail-badge">{committee.data.type}</div>
            <h1 class="committee-detail-title">{committee.data.name}</h1>
          </div>
          <span class={`px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap self-start ${
            committee.data.difficulty === 'Beginner' ? 'bg-green-100 text-green-800' :
            committee.data.difficulty === 'Intermediate' ? 'bg-blue-100 text-blue-800' :
            'bg-purple-100 text-purple-800'
          }`}>
            {committee.data.difficulty}
          </span>
        </div>

        <p class="committee-detail-desc">
          {committee.data.description}
        </p>

        <div class="committee-info-grid">
          <div class="committee-agenda-box">
            <h3 class="committee-agenda-header">
              <FileText className="icon-file-text" client:load/>
              Agenda Topics
            </h3>
            <ul class="committee-agenda-list">
              {committee.data.topics.map((topic) => (
                <li class="agenda-item">
                  <ChevronRight className="icon-chevron-right" client:load />
                  <span class="committee-agenda-text">{topic}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="committee-meta-col">
            <div class="committee-meta-item">
              <div class="committee-meta-icon-box">
                <Users className="icon-users" client:load />
              </div>
              <div>
                <div class="committee-meta-label">Committee Size</div>
                <div class="committee-meta-value">{committee.data.size}</div>
              </div>
            </div>
            <a href="#" class="committee-action-btn">
              Download Background Guide
            </a>
          </div>
        </div>
      </div>

      <div class="committee-content-prose prose prose-lg prose-headings:text-brand-dark prose-a:text-brand-orange">
        <h2 class="committee-letter-title">Welcome Letter</h2>
        <Content />
      </div>
    </div>
  </div>
</Layout>