---
import Layout from '../layouts/Layout.astro';
---
<Layout title="RIT MUN | Executive Board">
  <div class="max-w-4xl mx-auto px-6 py-20 animate-in fade-in">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold text-brand-dark mb-6">Executive Board</h1>
      <p class="text-xl text-gray-600">Meet the secretariat members organizing this year's conference.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {/* Secretary General */}
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-brand-dark mb-2">Jane Doe</h2>
        <p class="text-brand-orange font-semibold uppercase tracking-wide text-sm">Secretary-General</p>
      </div>

      {/* Director General */}
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-brand-dark mb-2">John Smith</h2>
        <p class="text-brand-orange font-semibold uppercase tracking-wide text-sm">Director-General</p>
      </div>
      
      {/* Under-Secretary-General of Committees */}
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-brand-dark mb-2">Alice Johnson</h2>
        <p class="text-brand-orange font-semibold uppercase tracking-wide text-sm">USG of Committees</p>
      </div>

      {/* Under-Secretary-General of Operations */}
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
        <h2 class="text-2xl font-bold text-brand-dark mb-2">Bob Williams</h2>
        <p class="text-brand-orange font-semibold uppercase tracking-wide text-sm">USG of Operations</p>
      </div>
    </div>
  </div>
</Layout>