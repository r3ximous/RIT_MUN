---
import { Globe } from 'lucide-react';
---
<footer class="bg-brand-dark text-white py-12 border-t border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-8">
    <div class="col-span-2">
      <div class="flex items-center gap-2 mb-4">
         <Globe className="w-6 h-6 text-brand-orange" client:idle />
         <span class="text-xl font-bold">RIT MUN</span>
      </div>
      <p class="text-gray-400 max-w-sm mb-6">
        Rochester Institute of Technology Model United Nations. Empowering students through diplomacy, debate, and international relations.
      </p>
    </div>
    
    <div>
      <h4 class="font-bold text-lg mb-4 text-brand-orange">Quick Links</h4>
      <ul class="space-y-2 text-gray-400">
        <li><a href="/committees" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Committees</a></li>
        <li><a href="/schedule" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Schedule</a></li>
        <li><a href="/registration" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Registration</a></li>
        <li><a href="/contact" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Contact Us</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-bold text-lg mb-4 text-brand-orange">Legal & Tools</h4>
      <ul class="space-y-2 text-gray-400">
        <li><a href="#" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Code of Conduct</a></li>
        <li><a href="#" class="hover:text-white transition-colors focus:ring-2 focus:ring-brand-orange rounded p-1">Privacy Policy</a></li>
        <li class="pt-4 mt-4 border-t border-gray-800 text-xs text-gray-500">
          Built with Astro & Tailwind
        </li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-gray-800 text-center text-gray-500 text-sm">
    &copy; {new Date().getFullYear()} RIT Model United Nations. All rights reserved.
  </div>
</footer>