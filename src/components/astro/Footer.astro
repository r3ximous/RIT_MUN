---
import { Globe } from 'lucide-react';
---
<footer class="layout-footer">
  <div class="footer-grid">
    <div class="footer-brand-col">
      <div class="footer-brand-logo">
         <Globe className="footer-globe-icon" client:idle />
         <span class="footer-brand-text">RIT MUN</span>
      </div>
      <p class="footer-brand-desc">
        Rochester Institute of Technology Model United Nations. Empowering students through diplomacy, debate, and international relations.
      </p>
    </div>
    
    <div>
      <h4 class="footer-nav-title">Quick Links</h4>
      <ul class="footer-nav-list">
        <li><a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/committees`} class="footer-nav-link">Committees</a></li>
        <li><a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/schedule`} class="footer-nav-link">Schedule</a></li>
        <li><a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/registration`} class="footer-nav-link">Registration</a></li>
        <li><a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/contact`} class="footer-nav-link">Contact Us</a></li>
      </ul>
    </div>

    <div>
      <h4 class="footer-nav-title">Legal & Tools</h4>
      <ul class="footer-nav-list">
        <li><a href="#" class="footer-nav-link">Code of Conduct</a></li>
        <li><a href="#" class="footer-nav-link">Privacy Policy</a></li>
        <li class="footer-copyright-item">
          Built with Astro & Tailwind
        </li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom-bar">
    &copy; {new Date().getFullYear()} RIT Model United Nations. All rights reserved.
  </div>
</footer>