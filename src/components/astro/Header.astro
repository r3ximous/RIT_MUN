---
import { Globe, Menu, X } from 'lucide-react';
const currentPath = Astro.url.pathname;
const navLinks = [
  { id: import.meta.env.BASE_URL === '/' ? '/committees' : import.meta.env.BASE_URL + '/committees', label: 'Committees' },
  { id: import.meta.env.BASE_URL === '/' ? '/schedule' : import.meta.env.BASE_URL + '/schedule', label: 'Schedule' },
  { id: import.meta.env.BASE_URL === '/' ? '/registration' : import.meta.env.BASE_URL + '/registration', label: 'Registration' },
  { id: import.meta.env.BASE_URL === '/' ? '/contact' : import.meta.env.BASE_URL + '/contact', label: 'Contact' }
];
---

<nav class="layout-header">
  <div class="header-container">
    
    {/* Logo Area */}
    <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/`} class="header-brand-link group">
      <div class="header-logo-box group-hover:rotate-12">
        <Globe client:idle className="header-globe-icon" />
      </div>
      <span class="header-brand-title">
        RIT <span class="text-brand-highlight">MUN</span>
      </span>
    </a>

    {/* Desktop Nav */}
    <div class="header-nav-desktop">
      {navLinks.filter(l => !l.id.endsWith('/registration')).map((link) => {
        const isActive = currentPath === link.id || (link.id !== '/' && currentPath.startsWith(link.id));
        return (
          <a
            href={link.id}
            class={`font-semibold text-sm uppercase tracking-wider transition-colors duration-200 hover:text-brand-orange focus:outline-none focus:ring-2 focus:ring-brand-orange p-1 rounded ${
              isActive ? 'text-brand-orange border-b-2 border-brand-orange py-1' : 'text-gray-300'
            }`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
      <a 
        href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/registration`}
        class="header-btn-register"
      >
        Register
      </a>
    </div>

    {/* Mobile Menu Toggle */}
    <button 
      id="mobile-menu-btn"
      class="header-mobile-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <Menu id="menu-icon-open" className="icon-block" client:idle />
      <X id="menu-icon-close" className="icon-hidden" client:idle />
    </button>
  </div>

  {/* Mobile Nav Dropdown */}
  <div id="mobile-menu" class="hidden header-mobile-menu">
    <div class="header-mobile-nav-list">
      {navLinks.map((link) => {
        const isActive = currentPath === link.id || (link.id !== '/' && currentPath.startsWith(link.id));
        return (
          <a
            href={link.id}
            class={`text-left font-semibold text-lg py-2 focus:outline-none focus:ring-2 focus:ring-brand-orange rounded px-2 ${
              isActive ? 'text-brand-orange' : 'text-gray-300 hover:text-white'
            }`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  }
</script>